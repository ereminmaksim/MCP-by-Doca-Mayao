{
  "name": "@mayao/mcp-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/http.ts",
    "dev:stdio": "tsx watch src/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^4.21.2",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2"
  }
}
